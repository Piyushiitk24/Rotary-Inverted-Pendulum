    {
      "number": 13,
      "kind": "content",
      "title": "Controller Design: Linear Controller",
      "subtitle": "",
      "elements": [
        {
          "type": "equation",
          "eq_id": "s13_control_poly",
          "latex": "\\begin{aligned} u&=-\\mathbf{K}\\mathbf{x} \\\\ (s^2+2\\zeta_1\\omega_1 s+\\omega_1^2)(s^2+2\\zeta_2\\omega_2 s+\\omega_2^2) \\\\ &=s^4+\\tilde{a}_3s^3+\\tilde{a}_2s^2+\\tilde{a}_1s+\\tilde{a}_0 \\end{aligned}",
          "x": 0.55,
          "y": 1.0,
          "w": 5.2,
          "h": 1.55,
          "font_size": 17
        },
        {
          "type": "equation",
          "eq_id": "s13_gain_formulas",
          "latex": "\\begin{aligned} k_{\\theta}&=-\\frac{\\tilde{a}_0}{A},\\qquad k_{\\dot{\\theta}}=-\\frac{\\tilde{a}_1}{A} \\\\ k_{\\dot{\\alpha}}&=\\frac{k_{\\dot{\\theta}}-\\tilde{a}_3}{B},\\qquad k_{\\alpha}=\\frac{k_{\\theta}-A-\\tilde{a}_2}{B} \\end{aligned}",
          "x": 0.55,
          "y": 2.7,
          "w": 5.2,
          "h": 1.35,
          "font_size": 18
        },
        {
          "type": "card",
          "x": 6.1,
          "y": 1.02,
          "w": 3.2,
          "h": 1.0,
          "title": "Chosen poles",
          "body": "omega1 = 15, zeta1 = 0.8\nomega2 = 1, zeta2 = 1\nomega1 is faster than the 12.47 rad/s fall rate",
          "bullets": null,
          "stripe": "0D6EAF",
          "fill": "FFFFFF",
          "title_color": "1B2A4A",
          "body_color": "3D5472",
          "title_size": 11,
          "body_size": 9.2,
          "bullet_size": null
        },
        {
          "type": "card",
          "x": 6.1,
          "y": 2.28,
          "w": 3.2,
          "h": 1.18,
          "title": "Calculated gains",
          "body": "K = [-2.232, -193.15, -4.702, -15.729]\nK_steps = [-9.92, -858.4, -20.9, -69.9]",
          "bullets": null,
          "stripe": "0A7A6E",
          "fill": "FFFFFF",
          "title_color": "1B2A4A",
          "body_color": "3D5472",
          "title_size": 11,
          "body_size": 9.1,
          "bullet_size": null
        },
        {
          "type": "card",
          "x": 6.1,
          "y": 3.72,
          "w": 3.2,
          "h": 0.98,
          "title": "Deployed firmware gains",
          "body": "31.5, 725.6, 28.3, 73.5",
          "bullets": null,
          "stripe": "D97706",
          "fill": "FFFFFF",
          "title_color": "1B2A4A",
          "body_color": "3D5472",
          "title_size": 11,
          "body_size": 10.2,
          "bullet_size": null
        }
      ],
      "key_contribution": false
    },
    {
      "number": 14,
      "kind": "content",
      "title": "Controller Design: Hybrid SMC",
      "subtitle": "",
      "elements": [
        {
          "type": "equation",
          "eq_id": "s14_hybrid_setup",
          "latex": "\\begin{aligned} \\ddot{\\alpha}&=A\\sin\\alpha+\\sin\\alpha\\cos\\alpha\\,\\dot{\\theta}^2-B\\cos\\alpha\\,\\ddot{\\theta} \\\\ s&=\\dot{\\alpha}+\\lambda\\alpha \\\\ f&=A\\sin\\alpha+\\sin\\alpha\\cos\\alpha\\,\\dot{\\theta}^2+\\lambda\\dot{\\alpha} \\end{aligned}",
          "x": 0.55,
          "y": 1.05,
          "w": 5.45,
          "h": 1.75,
          "font_size": 17
        },
        {
          "type": "equation",
          "eq_id": "s14_hybrid_law",
          "latex": "\\ddot{\\theta}=\\frac{f+K\\,\\mathrm{sat}(s/\\phi)}{B\\cos\\alpha}",
          "x": 0.55,
          "y": 3.2,
          "w": 5.45,
          "h": 0.72,
          "font_size": 24
        },
        {
          "type": "card",
          "x": 6.35,
          "y": 1.05,
          "w": 3.0,
          "h": 0.98,
          "title": "Parameters",
          "body": "lambda = 15\nK = 800\nphi = 50",
          "bullets": null,
          "stripe": "0D6EAF",
          "fill": "FFFFFF",
          "title_color": "1B2A4A",
          "body_color": "3D5472",
          "title_size": 11,
          "body_size": 10,
          "bullet_size": null
        },
        {
          "type": "card",
          "x": 6.35,
          "y": 2.35,
          "w": 3.0,
          "h": 1.35,
          "title": "Chattering reduction",
          "body": "sat(s/phi) replaces sgn(s).\nOutside phi the law behaves like sign control.\nInside phi it becomes smooth.",
          "bullets": null,
          "stripe": "0A7A6E",
          "fill": "FFFFFF",
          "title_color": "1B2A4A",
          "body_color": "3D5472",
          "title_size": 11,
          "body_size": 9.5,
          "bullet_size": null
        }
      ],
      "key_contribution": false
    },
    {
      "number": 15,
      "kind": "content",
      "title": "Controller Design: SMC Controller",
      "subtitle": "",
      "elements": [
        {
          "type": "equation",
          "eq_id": "s15_full_surface",
          "latex": "s=\\dot{\\alpha}+\\lambda_{\\alpha}\\alpha+k(\\dot{\\theta}_{\\mathrm{err}}+\\lambda_{\\theta}\\theta_{\\mathrm{err}})",
          "x": 0.55,
          "y": 1.1,
          "w": 5.75,
          "h": 0.82,
          "font_size": 23
        },
        {
          "type": "equation",
          "eq_id": "s15_full_law",
          "latex": "\\begin{aligned} \\ddot{\\theta}&=\\frac{f_0+\\lambda_{\\alpha}\\dot{\\alpha}+k\\lambda_{\\theta}\\dot{\\theta}_{\\mathrm{err}}-k\\ddot{\\theta}_{\\mathrm{ref}}+K\\,\\mathrm{sat}(s/\\phi)}{B\\cos\\alpha-k} \\\\ B\\cos\\alpha-k&>0 \\end{aligned}",
          "x": 0.55,
          "y": 2.45,
          "w": 5.85,
          "h": 1.65,
          "font_size": 17
        },
        {
          "type": "card",
          "x": 6.55,
          "y": 1.05,
          "w": 2.8,
          "h": 1.2,
          "title": "Parameters",
          "body": "lambda_alpha = 15\nlambda_theta = 2\nk = 0.5\nK = 800, phi = 50",
          "bullets": null,
          "stripe": "0D6EAF",
          "fill": "FFFFFF",
          "title_color": "1B2A4A",
          "body_color": "3D5472",
          "title_size": 11,
          "body_size": 9.5,
          "bullet_size": null
        },
        {
          "type": "card",
          "x": 6.55,
          "y": 2.6,
          "w": 2.8,
          "h": 1.55,
          "title": "Safety and smoothing",
          "body": "B cos(alpha) - k is the control effectiveness term.\nIt must stay positive.\nThe same sat(s/phi) law is used to avoid chattering.",
          "bullets": null,
          "stripe": "B91C1C",
          "fill": "FFFFFF",
          "title_color": "1B2A4A",
          "body_color": "3D5472",
          "title_size": 11,
          "body_size": 9.3,
          "bullet_size": null
        }
      ],
      "key_contribution": false
    },
